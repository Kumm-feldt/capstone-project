[node name="TabTwoText" type="Label" parent="Panel"]
layout_mode = 0
offset_left = 244.0
offset_top = 546.0
offset_right = 1812.0
offset_bottom = 903.0
theme_override_colors/font_color = Color(0.039215688, 0.24313726, 0, 1)
theme_override_fonts/font = ExtResource("2_x36it")
theme_override_font_sizes/font_size = 25
text = "The board is a hexagonal grid made of tiles.

Each player has a set of snake body discs and a head/tail indicator.

On your turn, place one snake‑disc tile so that it:

Connects to one of your existing snake discs.

Does not overlap another snake or an occupied tile.

Follows the original Creeper connection rules.
"

