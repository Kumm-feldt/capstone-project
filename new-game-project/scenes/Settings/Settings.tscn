[node name="SubtitleLabel" type="Label" parent="Panel/InstructionsPanel/ScrollContainer/VBoxContainer"]
layout_mode = 2
theme = ExtResource("4_f3efy")
text = "Goal of the Game"

[node name="Label2" type="Label" parent="Panel/InstructionsPanel/ScrollContainer/VBoxContainer"]
layout_mode = 2
theme = ExtResource("8_kj0qs")
theme_override_colors/font_color = Color(0.19215687, 0.21176471, 0.21960784, 0.7490196)
text = "The goal is to be the last player able to place a snake tile on 
the board.
Each snake is made of connected discs that grow from the
head to the tail. When a player cannot place any legal tile, 
they are eliminated. The last player remaining wins."

[node name="SubtitleLabel2" type="Label" parent="Panel/InstructionsPanel/ScrollContainer/VBoxContainer"]
layout_mode = 2
theme = ExtResource("4_f3efy")
text = "How to Play"

[node name="Label4" type="Label" parent="Panel/InstructionsPanel/ScrollContainer/VBoxContainer"]
layout_mode = 2
theme = ExtResource("8_kj0qs")
text = "The board is a hexagonal grid made of tiles. Each player
has a set of snake body discs and a head/tail indicator.
On your turn, place one snake‑disc tile so that it:
- Connects to one of your existing snake discs.
- Does not overlap another snake or an occupied tile.
- Follows the original Creeper connection rules.
"

